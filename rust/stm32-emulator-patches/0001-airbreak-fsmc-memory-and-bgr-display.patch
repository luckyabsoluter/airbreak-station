+        self.streams[0].finish_transfer();
+        self.streams[7].finish_transfer();
+        self.mark_transfer_complete(sys, 0);
+        self.mark_transfer_complete(sys, 7);
+        debug!("DMA1 SPI3 full-duplex transfer bytes={}", rx.len());
+        true
